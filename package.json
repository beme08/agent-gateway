{
  "name": "secure-enterprise-agent-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant agentic AI platform with RAG, role-gated tool execution, HR workflow automation, Supabase RLS, and audit tracing.",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "build:web": "cd apps/web && npm run build",
    "test:web": "cd apps/web && npm test",
    "test:api": "cd apps/api && pytest -q",
    "lint:web": "cd apps/web && npm run lint"
  },
  "engines": {
    "node": ">=18.17"
  }
}
